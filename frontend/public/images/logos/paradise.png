<style>
@media (min-width: 980px) {
    .container {
        max-width: 1240px !important;
    }
}
    
    @media (resolution: 150dpi) {

}
.offer_pop .google_map_wrap_animin{
	padding: 0 !important;
}
.offer_pop .google_map_wrap{
	//position:relative;
}
.offer_pop .google_map_wrap {
    top: 20% !important;
    height: auto !important;
    left: 0 !important;
    right: 0 !important;
    width: 90% !important;
	position:relative !important;
}



.video-play-button {
    position: absolute;
    z-index: 10;
    bottom: 4%;
    right: 0%;
    transform: translateX(-50%) translateY(-50%);
    box-sizing: content-box;
    display: block;
    width: 17px;
    height: 17px;
    /* background: #fa183d; */
    border-radius: 50%;
    padding: 15px 10px 18px 24px;
}

.video-play-button:before {
    content: "";
    position: absolute;
    z-index: 0;
    left: 55%;
    top: 50%;
    transform: translateX(-50%) translateY(-50%);
    display: block;
    width: 70px;
    height: 70px;
    background: #f06918;
    border-radius: 50%;
    animation: pulse-border 1500ms ease-out infinite;
}

.video-play-button:after {
    content: "";
    position: absolute;
    z-index: 1;
    left: 55%;
    top: 48%;
    transform: translateX(-50%) translateY(-50%);
    display: block;
    width: 52px;
    height: 52px;
    background: #f06918;
    border-radius: 50%;
    transition: all 200ms;
}

.video-play-button:hover:after {
  background-color: darken(#f06918, 10%);
}

.video-play-button img {
  position: relative;
  z-index: 3;
  max-width: 100%;
  width: auto;
  height: auto;
}

.video-play-button span {
    display: block;
    position: relative;
    z-index: 3;
    width: 0px;
    height: 0;
    border-left: 14px solid #fff;
    border-top: 9px solid transparent;
    border-bottom: 9px solid transparent;
}

@keyframes pulse-border {
  0% {
    transform: translateX(-50%) translateY(-50%) translateZ(0) scale(1);
    opacity: 1;
  }
  100% {
    transform: translateX(-50%) translateY(-50%) translateZ(0) scale(1.5);
    opacity: 0;
  }
}



.video-overlay {
  position: fixed;
  z-index: -1;
  top: 0;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0,0,0,0.80);
  opacity: 0;
  transition: all ease 500ms;
}

.video-overlay.open {
  position: fixed;
  z-index: 1000;
  opacity: 1;
}

.video-overlay-close {
  position: absolute;
  z-index: 1000;
  top: 15px;
  right: 20px;
  font-size: 36px;
  line-height: 1;
  font-weight: 400;
  color: #fff;
  text-decoration: none;
  cursor: pointer;
  transition: all 200ms;
}

.video-overlay-close:hover {
  color: #fa183d;
}

.video-overlay iframe {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translateX(-50%) translateY(-50%);
  /* width: 90%; */
  /* height: auto; */
  box-shadow: 0 0 15px rgba(0,0,0,0.75);
}


/** Banner custom css **/


@media only screen and (max-width: 768px) {
    /* For mobile phones: */
    .desktop {
        display: none; 
    }
    .mobile {
        display: block !important;
    }
    .gallery li a img {
        height: 100px !important;
    }
    .image_map{
        left: 55.2% !important;
        top: 88.8% !important;
        width: 38.5% !important;
        height: 4.5% !important;
        border-radius: 10px !important;
    }
    .banner{
        margin-top:25% !important;
    }
	}
    .gallery li a img{
        height: 140px;
        width:300px;
    }
    .image_map{
        position: absolute;
    left: 72.3%;
    top: 70%;
    width: 20.5%;
    height: 13.8%;
    outline: none;
    border-radius: 22px;
    }
	/* Effect for hover */
	.image_map:hover {
		border: 3px solid #ff5722;  /* Add border effect */
		background-color: rgba(255, 87, 34, 0.3); /* Add background color on hover */
		transition: all 0.3s ease; /* Smooth transition */
	}

	/* Effect for focus (keyboard interaction) */
	.image_map:focus {
		border: 3px solid #ff5722; /* Add border when focused */
		background-color: rgba(255, 87, 34, 0.5); /* Darker background */
		transition: all 0.3s ease;
	}

	/* Effect for active (click) */
	.image_map:active {
		transform: scale(0.98); /* Slightly shrink the button when clicked */
		border-color: #e64a19; /* Darken the border */
	}

    /** image2 **/
    @media only screen and (max-width: 768px) {
    .image_map1{
