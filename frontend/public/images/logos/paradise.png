    }
	/* Effect for hover */
	.image_map1:hover {
		border: 3px solid #ff5722;  /* Add border effect */
		background-color: rgba(255, 87, 34, 0.3); /* Add background color on hover */
		transition: all 0.3s ease; /* Smooth transition */
	}

	/* Effect for focus (keyboard interaction) */
	.image_map1:focus {
		border: 3px solid #ff5722; /* Add border when focused */
		background-color: rgba(255, 87, 34, 0.5); /* Darker background */
		transition: all 0.3s ease;
	}

	/* Effect for active (click) */
	.image_map1:active {
		transform: scale(0.98); /* Slightly shrink the button when clicked */
		border-color: #e64a19; /* Darken the border */
	}
    /** image3 **/
    @media only screen and (max-width: 768px) {
    .image_map3{
        left: 17.2% !important;
        top: 27.3% !important;
        width: 66.5% !important;
        height: 4.7% !important;
    }
    }
    .image_map3{
        position: absolute;
        left: 3.1%;
